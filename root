<style>
    body {
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: #0f172a;
        color: #e2e8f0;
    }

    header {
        text-align: center;
        padding: 50px 20px;
        background: linear-gradient(135deg, #1e293b, #0f172a);
    }

    header h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    header p {
        color: #94a3b8;
    }

    section {
        padding: 40px 10%;
    }

    h2 {
        border-left: 4px solid #38bdf8;
        padding-left: 10px;
        margin-bottom: 20px;
    }

    .card {
        background: #1e293b;
        padding: 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        transition: transform 0.3s;
    }

    .card:hover {
        transform: translateY(-5px);
    }

    /* Animated Skill Buttons */
    .skills {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
    }

    .skill-btn {
        padding: 10px 20px;
        border-radius: 25px;
        border: 2px solid #38bdf8;
        background: transparent;
        color: #38bdf8;
        cursor: pointer;
        transition: all 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .skill-btn::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        background: #38bdf8;
        top: 0;
        left: -100%;
        transition: 0.4s;
        z-index: -1;
    }

    .skill-btn:hover::before {
        left: 0;
    }

    .skill-btn:hover {
        color: #0f172a;
        transform: scale(1.1);
        box-shadow: 0 0 10px #38bdf8;
    }

    footer {
        text-align: center;
        padding: 20px;
        background: #020617;
        color: #64748b;
    }

    a {
        color: #38bdf8;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }
</style>
</head>

